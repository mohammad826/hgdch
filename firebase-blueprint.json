{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the mini app",
      "type": "object",
      "properties": {
        "balance": {
          "type": "number",
          "description": "User's coin balance"
        },
        "tasksCompleted": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of completed task IDs"
        }
      },
      "required": ["balance", "tasksCompleted"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global settings for the app",
      "type": "object",
      "properties": {
        "exchangeRate": { "type": "number" },
        "minWithdraw": { "type": "number" },
        "dollarRate": { "type": "number" }
      },
      "required": ["exchangeRate", "minWithdraw", "dollarRate"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "address": { "type": "string" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "number" }
      },
      "required": ["userId", "amount", "address", "method", "status", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "settings/global": {
      "schema": { "$ref": "Settings" },
      "description": "Global wallet and app settings"
    },
    "withdrawals/{withdrawalId}": {
      "schema": { "$ref": "Withdrawal" },
      "description": "Withdrawal requests"
    }
  }
}
